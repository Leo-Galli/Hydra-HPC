###############################################################################
# 🐉 HYDRA CLUSTER - GLOBAL CONFIGURATION MANIFEST
# Project: HackerGen 2026 | High-Performance Distributed Computing
# Version: 1.0.5 | Security Protocol: AES-RSA Hybrid
###############################################################################

# --- 🛰️ NETWORK ARCHITECTURE ---
# ZMQ Broker Interface Port (ROUTER/DEALER Topology)
HYDRA_BROKER_PORT=5555
# Peer Discovery Handshake Port (UDP Multicast)
HYDRA_DISCOVERY_PORT=5007
# Multicast Group Address (IANA Standard for Local Network)
HYDRA_MCAST_GRP=224.1.1.1
# Heartbeat Liveness Timeout (Milliseconds)
HYDRA_HEARTBEAT_LIVENESS=5000

# --- 🔐 SECURITY & ENCRYPTION (RSA-4096 / AES-256) ---
# Cluster Signature Secret (Unique Token for Authentication)
HYDRA_CLUSTER_SECRET="HYDRA_ALPHA_X_2026_SECURITY_TOKEN"
# RSA Keypair Directory (Auto-generated on initialization)
HYDRA_KEYS_PATH="./core/crypto/keys/"
# End-to-End Payload Encryption Toggle (Boolean)
HYDRA_ENCRYPT_PAYLOADS=True

# --- ⚖️ SCHEDULING & HEURISTICS ---
# Critical CPU Thermal Threshold (Celsius)
HYDRA_MAX_TEMP_THRESHOLD=85
# Minimum RAM Reservation for Host OS (Megabytes)
HYDRA_MIN_RAM_RESERVE=1024
# Maximum Concurrent Task Threads per Node (0 = Auto-detect cores)
HYDRA_MAX_CONCURRENT_TASKS=0

# --- 📊 MONITORING & TELEMETRY ---
# Streamlit HUD Refresh Frequency (Seconds)
HYDRA_HUD_REFRESH_RATE=1
# Logging Verbosity Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
HYDRA_LOG_LEVEL=INFO
# Persistent Data Output Directory
HYDRA_RESULTS_DIR="./data/results/"

# --- 🧬 NODE IDENTITY ---
# Worker Alias Prefix (e.g., "NODE_PI_01", "NODE_WS_ALPHA")
HYDRA_NODE_PREFIX="HYDRA_NODE_"